@inject LanguageState LanguageState
@implements IDisposable

<div class="language-selector">
    <label>Validation Error Message Language:</label>
    <div class="language-buttons">
        <button class="language-btn @GetActiveClass("en")" @onclick="SelectEnglish">
            English
        </button>
        <button class="language-btn @GetActiveClass("hu")" @onclick="SelectHungarian">
            Magyar
        </button>
    </div>
</div>

@code {
    private string selectedLanguage = "en";

    protected override void OnInitialized()
    {
        selectedLanguage = LanguageState.CurrentLanguage;
        LanguageState.OnLanguageChanged += StateHasChanged;
    }

    private void SelectEnglish()
    {
        SelectLanguage("en");
        StateHasChanged();
    }

    private void SelectHungarian()
    {
        SelectLanguage("hu");
        StateHasChanged();
    }

    private void SelectLanguage(string language)
    {
        selectedLanguage = language;
        LanguageState.SetLanguage(selectedLanguage);
    }

    private string GetActiveClass(string language)
    {
        return selectedLanguage == language ? "active" : "";
    }

    public void Dispose()
    {
        LanguageState.OnLanguageChanged -= StateHasChanged;
    }
}

<style>
    .language-selector {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .language-selector label {
        font-weight: 500;
        color: #333;
    }

    .language-buttons {
        display: flex;
        gap: 0.25rem;
    }

    .language-btn {
        padding: 0.5rem 1rem;
        border: 1px solid #ddd;
        background: white;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

    .language-btn:first-child {
        border-radius: 4px 0 0 4px;
    }

    .language-btn:last-child {
        border-radius: 0 4px 4px 0;
    }

    .language-btn:hover {
        background: #f5f5f5;
    }

    .language-btn.active {
        background: #1976d2;
        color: white;
        border-color: #1976d2;
    }
</style>
